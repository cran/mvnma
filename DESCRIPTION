Package: mvnma
Title: Multivariate Network Meta-Analysis using Bayesian Methods
Version: 0.1-0
Date: 2026-05-15
Depends: R (>= 4.0.0), meta (>= 8.3-0), netmeta (>= 3.4-0)
Imports: R2jags, coda, dplyr, magrittr, matrixStats, rlist, ggplot2,
        forcats
Authors@R: c(person("Theodoros", "Evrenoglou",
                    role = c("aut", "cre"),
                    email = "theodoros.evrenoglou@uniklinik-freiburg.de",
                    comment = c(ORCID = "0000-0003-3336-8058")),
             person("Guido", "Schwarzer",
